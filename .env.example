# Copy to `.env.local` for Next.js (never commit real secrets).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: used by `npm run seed` (Dashboard → Settings → API → secret key).
# Never expose in the browser or commit real values.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Guide page inquiry buttons (public URLs only)
# NEXT_PUBLIC_GUIDE_LINE_URL=https://line.me/R/ti/p/@your-id
# NEXT_PUBLIC_GUIDE_WHATSAPP_URL=https://wa.me/81xxxxxxxxxx

# Guide inquiry form → business inbox (Resend: https://resend.com)
RESEND_API_KEY=
GUIDE_INQUIRY_TO=your-business@gmail.com
# Optional after domain verify: JastipJP Guide <guide@yourdomain.com>
# GUIDE_INQUIRY_FROM=JastipJP Guide <onboarding@resend.dev>
